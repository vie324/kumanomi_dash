# ============================================================
# Supabase (Project Settings → API)
# ============================================================
# 公開用 URL / anon key（ブラウザに露出してOK。RLSで保護）
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# service role key（サーバー専用・絶対に公開しない。シード/管理用）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Anthropic Claude (AIフィードバック用)
# ============================================================
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# 任意: 既定モデル（未指定なら claude-sonnet-4-6）
ANTHROPIC_MODEL=claude-sonnet-4-6

# ============================================================
# シードスクリプト用（scripts/seed-members.mjs）
# ============================================================
# 5名アカウントの初期パスワード（初回ログイン後に変更推奨）
SEED_DEFAULT_PASSWORD=Kumanomi2026!
